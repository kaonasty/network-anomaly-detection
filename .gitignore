# ─── Python ───
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.egg

# ─── Virtual env ───
.venv/
venv/

# ─── MLflow ───
mlflow.db
mlruns/

# ─── Data (tracked by DVC) ───
# Ignore the actual data files, but allow .dvc and .gitignore
data/raw/*.csv
data/raw/*.parquet
data/features/*.parquet
data/features/*.txt
!data/raw/.gitignore
!data/features/.gitignore

# ─── Outputs ───
outputs/

# ─── OS ───
.DS_Store
Thumbs.db

# ─── IDE ───
.idea/
.vscode/
*.swp
*.swo

# ─── Docker ───
*.tar

# ─── DVC ───
# .dvc files should be committed, but cache should not
.dvc/cache/
.dvc/tmp/
